---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

// 1. Get the current active web address path
const { pathname } = Astro.url;

// 2. Clear any trailing slashes from both paths for bulletproof matching
const cleanPathname = pathname.replace(/\/$/, '');
const cleanHref = String(href).replace(/\/$/, '');

// 3. Determine if the current route matches the button link
const isActive = cleanPathname === cleanHref || cleanPathname.startsWith(cleanHref + '/');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
