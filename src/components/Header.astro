---
import { SITE_TITLE, NAV_LINKS, SOCIAL_LINKS } from '../consts';
import Search from './Search.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href={`${baseUrl}/`} class="logo">{SITE_TITLE}</a>

    <nav class="nav" aria-label="Main navigation">
      {NAV_LINKS.map(link => (
        <a
          href={`${baseUrl}${link.href}`}
          class:list={['nav-link', { active: currentPath.includes(link.href) && link.href !== '/' }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <!-- Search Island: hydrates only when visible (Astro Islands Architecture) -->
      <Search />
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" aria-label="GitHub" class="icon-link">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <a href={`${baseUrl}${SOCIAL_LINKS.rss}`} aria-label="RSS Feed" class="icon-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      </a>
      <button id="theme-toggle" aria-label="Toggle dark mode" class="theme-btn">
        <svg class="sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const stored = localStorage.getItem('theme');
  if (stored) {
    html.setAttribute('data-theme', stored);
  } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
    html.setAttribute('data-theme', 'dark');
  }
  toggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 1.5rem;
  }
  .logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text);
    white-space: nowrap;
  }
  .logo:hover { color: var(--accent); }
  .nav {
    display: flex;
    gap: 0.25rem;
  }
  .nav-link {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: background 0.2s, color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    background: var(--bg-secondary);
    color: var(--text);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .icon-link, .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: background 0.2s, color 0.2s;
    border: none;
    background: none;
    cursor: pointer;
  }
  .icon-link:hover, .theme-btn:hover {
    background: var(--bg-secondary);
    color: var(--text);
  }
  [data-theme="dark"] .sun { display: none; }
  [data-theme="light"] .moon, :not([data-theme="dark"]) .moon { display: none; }
  [data-theme="dark"] .moon { display: block; }

  @media (max-width: 768px) {
    .nav { display: none; }
    .header-inner { height: 56px; }
  }
</style>
