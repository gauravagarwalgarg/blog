---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

// 1. Get the current browser URL pathname safely
const { pathname } = Astro.url;

// 2. Convert href to a string safely and remove trailing slashes for clean matching
const strHref = href ? href.toString() : '';
const cleanPathname = pathname.replace(/\/$/, '');
const cleanHref = strHref.replace(/\/$/, '');

// 3. Determine if the path matches the active tab
const isActive = cleanPathname === cleanHref || cleanPathname.startsWith(cleanHref + '/');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
