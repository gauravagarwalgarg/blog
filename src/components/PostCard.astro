---
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS } from '../consts';
import type { Category } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  href: string;
  featured?: boolean;
}

const { title, description, pubDate, category, tags = [], href, featured = false } = Astro.props;
const label = CATEGORY_LABELS[category as Category] || category;
---

<article class:list={['post-card', { featured }]}>
  <a href={href} class="post-link">
    <div class="post-meta">
      <span class="tag">{label}</span>
      <span class="date"><FormattedDate date={pubDate} /></span>
    </div>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.slice(0, 3).map(tag => <span class="post-tag">#{tag}</span>)}
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 0;
    transition: background 0.2s;
  }
  .post-card:last-child { border-bottom: none; }
  .post-card.featured {
    padding: 2rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    border: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .date {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.375rem;
    transition: color 0.2s;
  }
  .post-link:hover .post-title { color: var(--accent); }
  .post-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .post-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .post-card { padding: 1.25rem 0; }
    .post-card.featured { padding: 1.25rem; }
    .post-title { font-size: 1.1rem; }
    .post-desc { font-size: 0.85rem; }
  }
</style>
