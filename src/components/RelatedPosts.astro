---
/**
 * Related Posts new_textShows posts with matching category/tags
 * 
 * Pure static component (no client JS needed).
 * Scores posts by category match + tag overlap, shows top 3.
 */
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  currentSlug: string;
  category: string;
  tags: string[];
}

const { currentSlug, category, tags } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter(p => p.id !== currentSlug && !p.data.draft);

// Score by relevance: category match (2 points) + each tag overlap (1 point)
const scored = otherPosts.map(post => {
  let score = 0;
  if (post.data.category === category) score += 2;
  const overlap = post.data.tags.filter(t => tags.includes(t)).length;
  score += overlap;
  return { post, score };
});

const related = scored
  .filter(s => s.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(s => s.post);
---

{related.length > 0 && (
  <aside class="related-posts">
    <h3>Related Posts</h3>
    <div class="related-grid">
      {related.map(post => (
        <a href={`${baseUrl}/blog/${post.id}/`} class="related-card">
          <span class="related-category tag">{post.data.category}</span>
          <h4>{post.data.title}</h4>
          <span class="related-date"><FormattedDate date={post.data.pubDate} /></span>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related-posts {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .related-posts h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .related-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }
  .related-card h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    line-height: 1.4;
  }
  .related-category {
    align-self: flex-start;
  }
  .related-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
