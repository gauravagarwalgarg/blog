---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { CATEGORY_LABELS } from '../consts';
import type { Category } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  category: string;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
  body?: string;
}

type PropsType = CollectionEntry<'blog'>['data'] & {
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
  body?: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags = [], headings = [], slug = '', body = '' } = Astro.props as PropsType;
const label = CATEGORY_LABELS[category as Category] || category;

// Calculate reading time
const words = body ? body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(words / 200));
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={title} description={description} />
</head>
<body>
  <Header />
  <main class="container">
    <article class="article">
      {heroImage && (
        <div class="hero-image">
          <Image width={960} height={480} src={heroImage} alt={title} />
        </div>
      )}
      <header class="article-header">
        <div class="article-meta">
          <span class="tag">{label}</span>
          <time><FormattedDate date={pubDate} /></time>
          {updatedDate && <span class="updated">· Updated <FormattedDate date={updatedDate} /></span>}
          {words > 0 && <span class="reading-time">· {readingTime} min read</span>}
        </div>
        <h1>{title}</h1>
        <p class="article-desc">{description}</p>
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map(tag => <span class="post-tag">#{tag}</span>)}
          </div>
        )}
      </header>

      {/* Table of Contents new_textonly shown for posts with 3+ headings */}
      {headings.length >= 3 && (
        <TableOfContents headings={headings} />
      )}

      <hr />
      <div class="prose">
        <slot />
      </div>

      {/* Related Posts new_textscored by category + tag overlap */}
      <RelatedPosts currentSlug={slug} category={category} tags={tags} />
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .hero-image {
    margin-bottom: 2rem;
  }
  .hero-image img {
    width: 100%;
    border-radius: 12px;
  }
  .article-header {
    margin-bottom: 1.5rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .reading-time {
    color: var(--text-muted);
  }
  .article-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .article-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }
  .article-tags {
    display: flex;
    gap: 0.75rem;
  }
  .post-tag {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .updated { font-style: italic; }
  hr { margin: 2rem 0; }

  @media (max-width: 768px) {
    .article { padding: 1rem 0; }
    .article-header h1 { font-size: 1.5rem; }
    .article-desc { font-size: 1rem; }
    .article-meta {
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.8rem;
    }
    .article-tags { gap: 0.5rem; }
    .hero-image { margin-bottom: 1.5rem; }
    .hero-image img { border-radius: 8px; }
  }
</style>
