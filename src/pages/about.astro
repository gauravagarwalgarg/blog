---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={`About | ${SITE_TITLE}`} description="About Gaurav Agarwal Software Engineer, Devices to Cloud." />
</head>
<body>
  <Header />
  <main class="container">
    <article class="about prose">
      <h1>About</h1>

      <p>
        I'm <strong>{SITE_AUTHOR}</strong> a software engineer working across the full spectrum from silicon to cloud. My domain spans cloud-native services, application software, hosted system software, kernel drivers, and BSP bring-up.
      </p>

      <blockquote>
        "Truth can only be found in one place: the code."
      </blockquote>

      <p>
        I'm perpetually exploring the boundary between distributed systems and bare-metal registers. Open to collaborating on products that bridge cloud-scale ambitions with hardware constraints.
      </p>

      <h2>What I Work With</h2>

      <h3>Languages</h3>
      <p>C, C++, Python, Go, Rust, Java, TypeScript, Bash, PowerShell, MATLAB</p>

      <h3>Embedded & Hardware</h3>
      <p>STM32, Texas Instruments, Xilinx Zynq, NVIDIA Jetson, ESP32, Raspberry Pi, BeagleBone FreeRTOS, Zephyr, Yocto, Buildroot, Device Tree, U-Boot, GDB, OpenOCD</p>

      <h3>Cloud & Infrastructure</h3>
      <p>AWS, GCP, Docker, Kubernetes, Terraform, Helm, Ansible, Prometheus, Grafana, Nginx</p>

      <h3>Protocols & Networking</h3>
      <p>ARINC 429/664, UART, SPI, CAN, I2C, CCSDS, TCP/UDP, gRPC, MQTT</p>

      <h3>DevOps & CI/CD</h3>
      <p>Git, GitHub Actions, GitLab CI, Jenkins, ArgoCD, CMake, Conan, Make</p>

      <h3>Tools</h3>
      <p>Vim/Neovim, VS Code, CLion, PyCharm, Wireshark, Valgrind, Doxygen, Postman, Jupyter</p>

      <h2>Philosophy</h2>
      <ul>
        <li>Write everything <strong>software</strong></li>
        <li>Anything <strong>open source</strong></li>
        <li>From <strong>silicon</strong> to <strong>cloud</strong></li>
        <li>Ship fast, break nothing</li>
        <li>Automate everything, always</li>
      </ul>

      <h2>Connect</h2>
      <p>
        <a href={SOCIAL_LINKS.github}>GitHub</a> ·
        <a href={SOCIAL_LINKS.linkedin}>LinkedIn</a> ·
        <a href={SOCIAL_LINKS.twitter}>X</a> ·
        <a href={SOCIAL_LINKS.stackoverflow}>Stack Overflow</a> ·
        <a href={SOCIAL_LINKS.leetcode}>LeetCode</a> ·
        <a href="mailto:gauravagarwalgarg@gmail.com">Email</a>
      </p>
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  .about {
    padding: 3rem 0;
  }
  .about h1 { margin-bottom: 1.5rem; }
  .about h2 { margin-top: 2.5rem; }
  .about h3 { margin-top: 1.5rem; font-size: 1rem; }

  @media (max-width: 768px) {
    .about { padding: 1.5rem 0; }
    .about h1 { font-size: 1.5rem; }
    .about h2 { margin-top: 2rem; }
  }
  @media (max-width: 480px) {
    .about { padding: 1rem 0; }
    .about h1 { font-size: 1.25rem; }
    .about h3 { font-size: 0.9rem; }
  }
</style>
