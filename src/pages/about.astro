---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={`About | ${SITE_TITLE}`} description="About Gaurav Agarwal Software Engineer, Devices to Cloud." />
</head>
<body>
  <Header />
  <main class="container">
    <article class="about prose">
      <h1>About</h1>

      <p>
        I'm <strong>{SITE_AUTHOR}</strong> a software engineer working across the full spectrum from embedded firmware to cloud-native systems. Currently building <strong>safety-critical avionics software</strong> where a segfault isn't a bug, it's a liability.
      </p>

      <p>
        My domain spans from <strong>Devices to Cloud</strong> cloud-native services, application software, hosted system software, kernel drivers, and BSP bring-up. I'm perpetually exploring the boundary between distributed systems and bare-metal registers.
      </p>

      <blockquote>
        "Truth can only be found in one place: the code."
      </blockquote>

      <h2>What I Work With</h2>

      <h3>Languages</h3>
      <p>C, C++, Python, Go, Rust, Java, TypeScript, Bash, PowerShell, MATLAB</p>

      <h3>Embedded & Hardware</h3>
      <p>STM32, Texas Instruments, Xilinx Zynq, NVIDIA Jetson, ESP32, Raspberry Pi, BeagleBone, Arduino FreeRTOS, Zephyr, Yocto, Buildroot, Device Tree, U-Boot, GDB, OpenOCD</p>

      <h3>Cloud & Infrastructure</h3>
      <p>AWS, GCP, Docker, Kubernetes, Terraform, Helm, Ansible, Prometheus, Grafana, Nginx</p>

      <h3>DevOps & CI/CD</h3>
      <p>Git, GitHub Actions, GitLab CI, Jenkins, ArgoCD, CMake, Conan, Make</p>

      <h3>Tools</h3>
      <p>Vim/Neovim, VS Code, CLion, PyCharm, Wireshark, Valgrind, Doxygen, Postman</p>

      <h2>Open Source</h2>
      <ul>
        <li><a href="https://github.com/GauravAgarwalGarg/CourseHub">CourseHub</a> Curated free courses, conferences & engineering blogs</li>
        <li><a href="https://github.com/GauravAgarwalGarg/LinuxPostInstallScripts">Linux Scripts</a> Post-install automation for Ubuntu LTS</li>
        <li><a href="https://github.com/GauravAgarwalGarg/dotvim">dotvim</a> Modern IDE-grade Vim configuration</li>
        <li><a href="https://github.com/GauravAgarwalGarg/AngelOneDashboard">AngelOne Dashboard</a> Stock market dashboard with real-time data & screeners</li>
      </ul>

      <h2>Connect</h2>
      <p>
        <a href={SOCIAL_LINKS.github}>GitHub</a> ·
        <a href={SOCIAL_LINKS.linkedin}>LinkedIn</a> ·
        <a href={SOCIAL_LINKS.twitter}>X</a> ·
        <a href="https://stackoverflow.com/users/6194954/gaurav-agarwal-garg" target="_blank" rel="noopener">Stack Overflow</a> ·
        <a href="https://leetcode.com/gauravagarwalgarg/" target="_blank" rel="noopener">LeetCode</a>
      </p>
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  .about {
    padding: 3rem 0;
  }
  .about h1 { margin-bottom: 1.5rem; }
  .about h2 { margin-top: 2.5rem; }
  .about h3 { margin-top: 1.5rem; font-size: 1rem; }

  @media (max-width: 768px) {
    .about { padding: 1.5rem 0; }
    .about h1 { font-size: 1.5rem; }
    .about h2 { margin-top: 2rem; }
  }
  @media (max-width: 480px) {
    .about { padding: 1rem 0; }
    .about h1 { font-size: 1.25rem; }
    .about h3 { font-size: 0.9rem; }
  }
</style>
