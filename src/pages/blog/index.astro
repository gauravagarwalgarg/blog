---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CATEGORIES, CATEGORY_LABELS } from '../../consts';
import type { Category } from '../../consts';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={`Blog new_text${SITE_TITLE}`} description={SITE_DESCRIPTION} />
</head>
<body>
  <Header />
  <main class="container">
    <section class="blog-header">
      <h1>Blog</h1>
      <p>Thoughts on software, systems, and everything in between.</p>
    </section>

    <!-- Category Filter -->
    <nav class="categories" aria-label="Filter by category">
      <a href={`${baseUrl}/blog`} class="cat-link active">All</a>
      {CATEGORIES.filter(c => c !== 'micro').map(cat => (
        <a href={`${baseUrl}/blog/category/${cat}`} class="cat-link">
          {CATEGORY_LABELS[cat as Category]}
        </a>
      ))}
    </nav>

    <!-- Posts -->
    <div class="posts-list">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          href={`${baseUrl}/blog/${post.id}/`}
          featured={i === 0}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="empty">No posts yet. Check back soon.</p>
    )}
  </main>
  <Footer />
</body>
</html>

<style>
  .blog-header {
    padding: 3rem 0 1rem;
  }
  .blog-header h1 { margin-bottom: 0.25rem; }
  .blog-header p { color: var(--text-secondary); margin: 0; }
  .categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }
  .cat-link {
    padding: 0.375rem 0.875rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .cat-link:hover, .cat-link.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .posts-list { display: flex; flex-direction: column; }
  .empty { color: var(--text-muted); padding: 3rem 0; text-align: center; }
</style>
