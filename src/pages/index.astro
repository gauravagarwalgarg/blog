---
import { getCollection } from 'astro:content';

// Fixed clean single-level path imports
import FormattedDate from '../components/FormattedDate.astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Declare 'posts' exactly ONCE
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Pre-calculate subfolder pathing securely for GitHub Pages compatibility
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Your HTML code below remains exactly the same -->
<ul>
	{
		posts.map((post) => (
			<li>
				<a href={`${baseUrl}/blog/${post.id}/`}>
					<img width={720} height={360} src={post.data.heroImage} alt="" />
					<h4 class="title">{post.data.title}</h4>
					<p class="date">
						<FormattedDate date={post.data.pubDate} />
					</p>
				</a>
			</li>
		))
	}
</ul>
