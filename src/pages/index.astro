---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_TAGLINE, SITE_BIO, SOCIAL_LINKS, WORK_EXPERIENCE, BOOKMARKS, CATEGORIES, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS, CATEGORY_ICONS } from '../consts';
import type { Category } from '../consts';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 5);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Get categories with content
const categoriesWithContent = CATEGORIES
  .filter(c => c !== 'micro')
  .map(cat => ({
    slug: cat,
    label: CATEGORY_LABELS[cat],
    description: CATEGORY_DESCRIPTIONS[cat] || '',
    icon: CATEGORY_ICONS[cat] || cat.slice(0, 2).toUpperCase(),
    count: posts.filter(p => p.data.category === cat).length,
  }))
  .filter(c => c.count > 0);
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
  <Header />
  <main class="container">

    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">{SITE_TAGLINE}</h1>
        <p class="hero-bio">{SITE_BIO}</p>
        <a href={`${baseUrl}/about`} class="hero-cta">Read more about me →</a>
      </div>
      <div class="hero-social">
        <a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener" aria-label="Twitter">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </section>

    <!-- Main two-column layout -->
    <div class="home-grid">

      <!-- Left column: Articles -->
      <section class="articles-column">
        <div class="section-title-row">
          <span class="section-icon">📄</span>
          <h2>Articles</h2>
        </div>
        <div class="articles-list">
          {latestPosts.map((post) => (
            <article class="article-item">
              <div class="article-date-bar">
                <FormattedDate date={post.data.pubDate} />
              </div>
              <h3 class="article-title">
                <a href={`${baseUrl}/posts/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p class="article-desc">{post.data.description}</p>
              <a href={`${baseUrl}/posts/${post.id}/`} class="article-link">Read article →</a>
            </article>
          ))}
        </div>
        <a href={`${baseUrl}/posts`} class="view-all-link">View all articles →</a>
      </section>

      <!-- Right column: Sidebar -->
      <aside class="sidebar-column">

        <!-- Work -->
        <div class="sidebar-card">
          <div class="sidebar-card-title">
            <span class="sidebar-icon">💼</span>
            <h3>Work</h3>
          </div>
          <div class="work-list">
            {WORK_EXPERIENCE.map((job) => (
              <div class="work-item">
                <div class="work-info">
                  <span class="work-company">{job.company}</span>
                  <span class="work-role">{job.role}</span>
                </div>
                <span class="work-period">{job.period}</span>
              </div>
            ))}
          </div>
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" class="sidebar-link">More on LinkedIn →</a>
        </div>

        <!-- Bookmarks -->
        <div class="sidebar-card">
          <div class="sidebar-card-title">
            <span class="sidebar-icon">🔖</span>
            <h3>Bookmarks</h3>
          </div>
          <p class="sidebar-card-desc">Resources I find valuable and recommend to anyone interested in systems and engineering.</p>
          <div class="bookmark-list">
            {BOOKMARKS.map((bm) => (
              <div class="bookmark-item">
                <span class="bookmark-title">{bm.title}</span>
                <span class="bookmark-author">{bm.author}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Stay up to date -->
        <div class="sidebar-card">
          <div class="sidebar-card-title">
            <span class="sidebar-icon">📬</span>
            <h3>Stay up to date</h3>
          </div>
          <p class="sidebar-card-desc">Get notified when I publish something new, and unsubscribe at any time.</p>
          <a href={`${baseUrl}${SOCIAL_LINKS.rss}`} class="rss-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
            Subscribe via RSS
          </a>
        </div>

      </aside>
    </div>

    <!-- Browse by Category section (like Concepts page) -->
    <section class="categories-section">
      <div class="section-title-row">
        <h2>Browse by Category</h2>
      </div>
      <div class="categories-grid">
        {categoriesWithContent.map((cat) => (
          <a href={`${baseUrl}/posts/category/${cat.slug}`} class="category-card">
            <div class="category-card-header">
              <span class="category-badge">{cat.icon}</span>
              <span class="category-count">{cat.count} articles</span>
            </div>
            <h3 class="category-card-title">{cat.label}</h3>
            {cat.description && <p class="category-card-desc">{cat.description}</p>}
            <span class="category-card-link">Explore articles →</span>
          </a>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
  /* Hero */
  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .hero-bio {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 1.25rem;
  }
  .hero-cta {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    transition: all 0.2s;
  }
  .hero-cta:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .hero-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: color 0.2s, background 0.2s;
  }
  .hero-social a:hover {
    color: var(--text);
    background: var(--bg-secondary);
  }

  /* Two-column grid */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: start;
  }

  /* Articles column */
  .section-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .section-title-row h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }
  .section-icon {
    font-size: 1rem;
  }

  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .article-item {
    padding: 1.25rem 1rem;
    border-left: 3px solid var(--border);
    margin-left: 0.25rem;
    transition: border-color 0.2s;
  }
  .article-item:hover {
    border-left-color: var(--accent);
  }
  .article-date-bar {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .article-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .article-title a {
    color: var(--text);
    text-decoration: none;
  }
  .article-title a:hover {
    color: var(--accent);
  }
  .article-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 0.5rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }
  .view-all-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
  }

  /* Sidebar */
  .sidebar-column {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .sidebar-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .sidebar-card-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .sidebar-card-title h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
  }
  .sidebar-icon {
    font-size: 0.9rem;
  }
  .sidebar-card-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .sidebar-link {
    display: block;
    margin-top: 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }

  /* Work list */
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .work-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .work-info {
    display: flex;
    flex-direction: column;
  }
  .work-company {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }
  .work-role {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .work-period {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Bookmarks */
  .bookmark-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .bookmark-item {
    display: flex;
    flex-direction: column;
  }
  .bookmark-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }
  .bookmark-author {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* RSS Button */
  .rss-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: white;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    transition: background 0.2s;
  }
  .rss-btn:hover {
    background: var(--accent-hover);
    color: white;
  }

  /* Categories section */
  .categories-section {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .category-card {
    display: block;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }
  .category-card:hover {
    border-color: var(--accent);
  }
  .category-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .category-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
  }
  .category-count {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .category-card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: var(--text);
  }
  .category-card-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .category-card-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .sidebar-column {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }
  }
  @media (max-width: 768px) {
    .hero { padding: 2rem 0 2rem; }
    .hero-title { font-size: 1.75rem; }
    .categories-grid { grid-template-columns: 1fr; }
    .sidebar-column { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: 1.5rem; }
    .hero-bio { font-size: 0.9rem; }
  }
</style>
