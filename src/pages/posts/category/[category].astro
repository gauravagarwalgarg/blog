---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORIES, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS, CATEGORY_ICONS } from '../../../consts';
import type { Category } from '../../../consts';

export async function getStaticPaths() {
  return CATEGORIES.filter(c => c !== 'micro').map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const label = CATEGORY_LABELS[category as Category] || category;
const description = CATEGORY_DESCRIPTIONS[category as Category] || `Articles about ${label.toLowerCase()}.`;
const icon = CATEGORY_ICONS[category as Category] || category.slice(0, 2).toUpperCase();
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={`${label} | ${SITE_TITLE}`} description={description} />
</head>
<body>
  <Header />
  <main class="container">

    <!-- Hero banner -->
    <section class="category-hero">
      <div class="category-hero-badge">{icon}</div>
      <h1>{label}</h1>
      <p>{description}</p>
      <div class="category-hero-stats">
        <span class="stat-pill">{posts.length} articles</span>
      </div>
    </section>

    <!-- Category filter nav -->
    <nav class="filter-nav" aria-label="Filter by category">
      <a href={`${baseUrl}/posts`} class="filter-link">All</a>
      {CATEGORIES.filter(c => c !== 'micro').map(cat => (
        <a
          href={`${baseUrl}/posts/category/${cat}`}
          class:list={['filter-link', { active: cat === category }]}
        >
          {CATEGORY_LABELS[cat as Category]}
        </a>
      ))}
    </nav>

    <!-- Articles feed -->
    <div class="all-articles-header">
      <h2>{label} Articles</h2>
    </div>

    <div class="articles-feed">
      {posts.map((post) => (
        <article class="article-card">
          <div class="article-card-body">
            <div class="article-card-meta">
              <span class="meta-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <FormattedDate date={post.data.pubDate} />
              </span>
              {post.data.readingTime && (
                <span class="meta-reading">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {post.data.readingTime}
                </span>
              )}
            </div>
            <h3 class="article-card-title">
              <a href={`${baseUrl}/posts/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p class="article-card-desc">{post.data.description}</p>
            <div class="article-card-footer">
              <div class="article-card-tags">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {post.data.tags.length > 3 && (
                  <span class="tag-more">+{post.data.tags.length - 3}</span>
                )}
              </div>
              <a href={`${baseUrl}/posts/${post.id}/`} class="read-link">Read article →</a>
            </div>
          </div>
          <div class="article-card-icon">
            <span class="category-dot"></span>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="empty">No posts in this category yet. Check back soon.</p>
    )}
  </main>
  <Footer />
</body>
</html>

<style>
  /* Hero */
  .category-hero {
    background: var(--hero-gradient);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
    margin: 2rem 0;
  }
  .category-hero-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .category-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .category-hero p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 0 1rem;
    line-height: 1.6;
  }
  .category-hero-stats {
    display: flex;
    gap: 0.5rem;
  }
  .stat-pill {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  /* Filter nav */
  .filter-nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    overflow-x: auto;
  }
  .filter-link {
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    white-space: nowrap;
    transition: all 0.2s;
  }
  .filter-link:hover, .filter-link.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  /* Section header */
  .all-articles-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .all-articles-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  /* Article cards */
  .articles-feed {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .article-card {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.2s;
  }
  .article-card:hover {
    border-color: var(--border-hover);
  }
  .article-card-body {
    flex: 1;
    min-width: 0;
  }
  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .meta-date, .meta-reading {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .article-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .article-card-title a {
    color: var(--text);
    text-decoration: none;
  }
  .article-card-title a:hover {
    color: var(--accent);
  }
  .article-card-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .article-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tag-more {
    font-size: 0.7rem;
    color: var(--text-muted);
    padding: 0.2em 0.5em;
    background: var(--bg-secondary);
    border-radius: 4px;
  }
  .read-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .article-card-icon {
    margin-left: 1rem;
    flex-shrink: 0;
  }
  .category-dot {
    display: block;
    width: 32px;
    height: 32px;
    background: var(--accent-dim);
    border-radius: 50%;
    border: 2px solid var(--accent);
  }
  .empty {
    color: var(--text-muted);
    padding: 3rem 0;
    text-align: center;
  }

  @media (max-width: 768px) {
    .category-hero { padding: 1.5rem; margin: 1rem 0; }
    .category-hero h1 { font-size: 1.5rem; }
    .article-card { padding: 1.25rem; }
    .article-card-title { font-size: 1rem; }
    .article-card-icon { display: none; }
    .article-card-footer { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .filter-nav { gap: 0.35rem; }
    .filter-link { padding: 0.35rem 0.7rem; font-size: 0.75rem; }
  }
  @media (max-width: 480px) {
    .category-hero { padding: 1.25rem; border-radius: 12px; }
    .category-hero h1 { font-size: 1.25rem; }
    .category-hero p { font-size: 0.85rem; }
    .article-card { padding: 1rem; border-radius: 8px; }
    .article-card-desc { font-size: 0.8rem; }
  }
</style>
