---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORY_LABELS } from '../consts';
import type { Category } from '../consts';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by month
const grouped = posts.reduce((acc, post) => {
  const key = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
  if (!acc[key]) acc[key] = [];
  acc[key].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <BaseHead title={`Summary | ${SITE_TITLE}`} description="Monthly publishing summary what was written, which topics were covered, and the writing cadence." />
</head>
<body>
  <Header />
  <main class="container">
    <section class="page-header">
      <h1>Monthly Summary</h1>
      <p>Publishing log grouped by month. A snapshot of what was written, topics covered, and writing cadence over time.</p>
      <div class="summary-stats">
        <span class="stat">{posts.length} articles</span>
        <span class="stat">{Object.keys(grouped).length} months active</span>
      </div>
    </section>

    <div class="timeline">
      {Object.entries(grouped).map(([month, monthPosts]) => (
        <section class="month-group">
          <div class="month-header">
            <h2>{month}</h2>
            <span class="month-count">{monthPosts.length} {monthPosts.length === 1 ? 'post' : 'posts'}</span>
          </div>
          <div class="month-posts">
            {monthPosts.map(post => (
              <a href={`${baseUrl}/posts/${post.id}/`} class="summary-post">
                <span class="summary-category">{CATEGORY_LABELS[post.data.category as Category] || post.data.category}</span>
                <span class="summary-title">{post.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-secondary); margin: 0 0 1rem; max-width: 520px; line-height: 1.6; }
  .summary-stats { display: flex; gap: 1rem; }
  .stat {
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 100px;
    font-weight: 500;
  }

  .timeline { padding: 1rem 0; }
  .month-group { margin-bottom: 2rem; }
  .month-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .month-header h2 { font-size: 1.1rem; font-weight: 700; margin: 0; }
  .month-count { font-size: 0.8rem; color: var(--text-muted); }

  .month-posts { display: flex; flex-direction: column; gap: 0.5rem; }
  .summary-post {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .summary-post:hover { background: var(--bg-secondary); }
  .summary-category {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    min-width: 100px;
    text-align: center;
  }
  .summary-title { font-size: 0.9rem; font-weight: 500; color: var(--text); }

  @media (max-width: 768px) {
    .page-header { padding: 2rem 0 1.5rem; }
    .page-header h1 { font-size: 1.5rem; }
    .summary-post { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .summary-category { min-width: auto; }
  }
</style>
